
//PROGRAM 1 
// print 1 to 10 using for loop 

#include <iostream> 
using namespace std;

int main() {
    for(int i =1; i <= 10; i++){
     cout << i << " ";
   } 
}





//PROGRAM 2
// print even even number from 0 to 10

#include <iostream> 
using namespace std;

int main() {
    for(int i =0; i <= 10; i += 2){
     cout << i << " ";
   } 
}





//PROGRAM 3
// print 1 tp 10 using for while loop

#include <iostream> 
using namespace std;

int main() { 
    int i = 1;
    while(i <= 10){
     cout << i << " ";
     i++;
   } 
} 


//PROGRAM 4
// print odd number for while loop

#include <iostream> 
using namespace std;

int main() { 
    int i = 1;
    while(i <= 10){
     cout << i << " ";
     i+=2;
   } 
}


//PROGRAM 5
//print 1 to 10 using do while



#include <iostream>
using namespace std;

int main() {
  int i =1;
  do {
      cout << i << " ";
      i++;
  } while (i <= 10);

}




